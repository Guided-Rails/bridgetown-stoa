<!doctype html>
<html lang="{{ site.locale || 'en' }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% if resource.data.title %}{{ resource.data.title }} | {% end %}{{ site.metadata.title }}</title>
    {% if resource.data.description %}<meta name="description" content="{{ resource.data.description }}">{% end %}
    <link rel="stylesheet" href="{%= asset_path :css %}">
  </head>
  <body>
    <header class="stoa-header">
      <a href="/" class="stoa-site-title">{{ site.metadata.title }}</a>
    </header>
    <main class="stoa-main">
      {%= yield %}
    </main>
    <footer class="stoa-footer">
      <small>Built with <a href="https://www.bridgetownrb.com">Bridgetown</a> + <a href="https://github.com/Guided-Rails/bridgetown-stoa">Stoa</a>.</small>
    </footer>
    <script src="{%= asset_path :js %}" defer></script>
  </body>
</html>
